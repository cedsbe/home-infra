{
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "github",
    "terraform"
  ],
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:wellarchitected.github.com)",
      "Bash(git check-ignore *)",
      "Bash(git remote *)",
      "Bash(git status *)",
      "Bash(git rebase *)",
      "Bash(git stash *)",
      "Bash(git ls-remote *)",
      "Bash(gh pr list *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)"
    ]
  }
}
