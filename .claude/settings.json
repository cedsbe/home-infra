{
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/post-edit-validate.sh",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(task *)",
      "Bash(terraform fmt *)",
      "Bash(terraform validate *)",
      "Bash(terraform plan *)",
      "Bash(terraform output *)",
      "Bash(terraform init *)",
      "Bash(terraform workspace *)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl diff *)",
      "Bash(kubectl kustomize *)",
      "Bash(talosctl health *)",
      "Bash(talosctl get *)",
      "Bash(talosctl read *)",
      "Bash(talosctl version *)",
      "Bash(argocd app get *)",
      "Bash(argocd app list *)",
      "Bash(argocd app diff *)",
      "Bash(helm template *)",
      "Bash(helm list *)",
      "Bash(packer validate *)",
      "Bash(packer inspect *)",
      "Bash(packer init *)",
      "Bash(pre-commit run *)",
      "Bash(kubeconform *)",
      "Bash(kustomize build *)",
      "Bash(tflint *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(git fetch *)",
      "Bash(git rebase *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(jq *)",
      "mcp__github__create_pull_request",
      "mcp__github__pull_request_read",
      "mcp__github__list_pull_requests",
      "mcp__github__search_pull_requests",
      "mcp__github__issue_read",
      "mcp__github__list_issues",
      "mcp__github__search_issues",
      "mcp__github__get_file_contents",
      "mcp__github__search_code",
      "mcp__github__search_commits",
      "mcp__github__list_commits",
      "mcp__github__get_commit",
      "mcp__github__list_branches",
      "mcp__github__get_latest_release",
      "mcp__github__list_releases",
      "mcp__github__list_tags",
      "mcp__github__get_me",
      "mcp__terraform__get_latest_provider_version",
      "mcp__terraform__get_latest_module_version",
      "mcp__terraform__get_provider_capabilities",
      "mcp__terraform__get_provider_details",
      "mcp__terraform__get_module_details",
      "mcp__terraform__search_modules",
      "mcp__terraform__search_providers",
      "mcp__terraform__search_policies",
      "mcp__terraform__get_policy_details"
    ],
    "ask": [
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(kubectl apply *)",
      "Bash(kubectl delete *)",
      "Bash(kubectl exec *)",
      "Bash(talosctl apply-config *)",
      "Bash(talosctl reset *)",
      "Bash(talosctl upgrade *)",
      "Bash(argocd app sync *)",
      "Bash(argocd app delete *)",
      "Bash(packer build *)",
      "Bash(git push *)",
      "Bash(git-crypt *)",
      "Bash(rm -rf *)"
    ]
  }
}
