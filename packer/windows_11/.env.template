# NOTE: Credentials are now managed in the shared packer/.env file.
#
# Setup:
#   cp packer/.env.template packer/.env
#   # Edit packer/.env with your actual values
#
# Variables used by this template:
#   PKR_VAR_proxmox_api_token     - Proxmox API token
#   PKR_VAR_proxmox_username      - Proxmox username (user@pve!token-name)
#   PKR_VAR_winrm_password        - Windows Administrator password
#   PKR_VAR_win11_clone_vm_id     - VM ID of Win11 base template (clone builds only)
