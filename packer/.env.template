# Shared Packer environment variables
# Copy this file to packer/.env and fill in your actual values
# This file is shared by all Windows templates (Windows Server 2025 and Windows 11)
#
# Usage:
#   cp packer/.env.template packer/.env
#   # Edit packer/.env with your actual credentials

# ─── Proxmox credentials (shared across all templates) ────────────────────────

# Proxmox API Token (create in Proxmox VE web interface)
PKR_VAR_proxmox_api_token=your-proxmox-api-token-here

# Proxmox username (format: username@pve!token-name)
PKR_VAR_proxmox_username=your-username@pve!your-token-name

# WinRM password for the Windows Administrator account (used during builds)
PKR_VAR_winrm_password=your-secure-password

# ─── Clone VM IDs (template-specific) ─────────────────────────────────────────
# These are the VM IDs of the base ISO-built templates used as clone sources.
# Each template uses its own variable to avoid conflicts.

# VM ID of the Windows Server 2025 base template (ISO build output)
PKR_VAR_ws2025_clone_vm_id=100

# VM ID of the Windows 11 base template (ISO build output)
PKR_VAR_win11_clone_vm_id=101

# ─── Optional ─────────────────────────────────────────────────────────────────
# Enable verbose Packer logging
# PACKER_LOG=1
