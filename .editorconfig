# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{hcl,tf,tfvars}]
indent_style = space
indent_size = 2

[*.pkr.hcl]
indent_style = space
indent_size = 2

[*.pkrvars.hcl]
indent_style = space
indent_size = 2

[*.{yaml,yml}]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.sh]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[*.ps1]
indent_style = space
indent_size = 4
end_of_line = crlf
